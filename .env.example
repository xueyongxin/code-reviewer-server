DATABASE_URL=postgresql://lance:lance@localhost:5432/code_reviewer
PORT=3100
NODE_ENV=development
# 生产必须设置强随机密钥
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# 本地联调短信/邮箱：设为 1 时发码接口会回传 code（未发真实通道）
# 注意：NODE_ENV=production 时即使误开也不回传；生产切勿依赖此开关
SMS_DEBUG=1
# EMAIL_DEBUG=1  # 可选；与 SMS_DEBUG 任一为 1 即可回传验证码
# seed：设为 1 时会 purge 非超管用户与全部组织（危险）
# SEED_PURGE=1
# SEED_ADMIN_PASSWORD=change-me
# 可选：额外 CORS 来源（逗号分隔）；主来源以配置中心为准
# CORS_ORIGINS=https://app.example.com
# 邀请链接兜底（优先读配置中心 client.auth_web_base）
# ADMIN_WEB_BASE=http://localhost:3000
